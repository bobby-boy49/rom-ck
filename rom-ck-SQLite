#!/usr/bin/env python3
import os
import sys
import hashlib
import zipfile
import sqlite3
import xml.etree.ElementTree as ET
from concurrent.futures import ThreadPoolExecutor, as_completed

# ==============================================================================
# MASTER VALID EXTENSIONS LIST
# ==============================================================================
VALID_EXTENSIONS = (
    # --- Compression / Archives ---
    '.zip',                          # Arcade (MAME) / Compressed Cartridges
    
    # --- Nintendo ---
    '.z64', '.v64', '.n64', '.rom',  # Nintendo 64
    '.gba', '.gbc', '.gb',           # Game Boy, Color, Advance
    '.nes', '.sfc', '.smc',          # NES / SNES
    '.nds', '.3ds',                  # Nintendo DS / 3DS
    '.iso',                          # GameCube / Wii (Raw Discs)
    
    # --- Sega ---
    '.md', '.bin', '.gen',           # Genesis / Mega Drive
    '.32x',                          # Sega 32X
    '.sms',                          # Sega Master System
    '.gg',                           # Sega Game Gear
    
    # --- Atari ---
    '.a26', '.a52', '.a78', '.lnx',  # 2600, 5200, 7800, Lynx
    
    # --- SNK & Bandai ---
    '.ngp', '.ngc',                  # Neo Geo Pocket / Color
    '.ws', '.wsc',                   # WonderSwan / Color
    
    # --- NEC & Miscellaneous ---
    '.pce',                          # TurboGrafx-16 / PC Engine
    '.pbp',                          # PlayStation Portable / PSX Eboots
    '.chd', '.cue'                   # CD/Disc compression formats
)

def parse_dats(dat_path, db_path="dat_cache.db"):
    if os.path.exists(db_path):
        try:
            os.remove(db_path)
        except OSError:
            pass

    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    cursor.execute("PRAGMA synchronous = OFF;")
    cursor.execute("PRAGMA journal_mode = MEMORY;")
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS roms (
            sha256 TEXT,
            sha1 TEXT,
            md5 TEXT,
            game_name TEXT,
            rom_name TEXT
        )
    ''')

    dat_files = []
    if os.path.isdir(dat_path):
        for root, _, files in os.walk(dat_path):
            for file in files:
                if file.lower().endswith('.dat'):
                    dat_files.append(os.path.join(root, file))
    elif os.path.isfile(dat_path):
        dat_files.append(dat_path)

    if not dat_files:
        print(f"Error: No valid .dat file found at {dat_path}")
        sys.exit(1)

    insert_buffer = []
    buffer_size = 50000

    print("Parsing DAT files into disk-backed cache. This protects your system memory...")
    for dat in dat_files:
        try:
            context = ET.iterparse(dat, events=('start', 'end'))
            context = iter(context)
            event, root = next(context)
            
            current_game = None
            for event, elem in context:
                if event == 'start':
                    if elem.tag in ('game', 'machine'):
                        current_game = elem.get('name')
                elif event == 'end':
                    if elem.tag == 'rom' and current_game:
                        sha256 = elem.get('sha256')
                        sha1 = elem.get('sha1')
                        md5 = elem.get('md5')
                        rom_file_name = elem.get('name')

                        has_custom_name = True
                        if rom_file_name:
                            rom_lower = rom_file_name.lower()
                            game_lower = current_game.lower()
                            
                            # Check if the filename exactly matches [Game Name] + [Any Extension]
                            if any(rom_lower == f"{game_lower}{ext.lower()}" for ext in VALID_EXTENSIONS):
                                has_custom_name = False

                        db_rom_name = rom_file_name if (rom_file_name and has_custom_name) else None
                        sha256_lower = sha256.lower() if sha256 else None
                        sha1_lower = sha1.lower() if sha1 else None
                        md5_lower = md5.lower() if md5 else None

                        if sha1_lower or sha256_lower or md5_lower:
                            insert_buffer.append((sha256_lower, sha1_lower, md5_lower, current_game, db_rom_name))

                        if len(insert_buffer) >= buffer_size:
                            cursor.executemany("INSERT INTO roms VALUES (?, ?, ?, ?, ?)", insert_buffer)
                            insert_buffer.clear()
                    
                    if elem.tag in ('rom', 'game', 'machine'):
                        root.clear()
                        
        except (ET.ParseError, IOError) as e:
            print(f"Error parsing DAT {dat}: {e}")
            continue

    if insert_buffer:
        cursor.executemany("INSERT INTO roms VALUES (?, ?, ?, ?, ?)", insert_buffer)

    print("Building database indexes for near-instant hash retrieval...")
    cursor.execute("CREATE INDEX idx_sha1 ON roms(sha1);")
    cursor.execute("CREATE INDEX idx_sha256 ON roms(sha256);")
    cursor.execute("CREATE INDEX idx_md5 ON roms(md5);")
    
    conn.commit()
    conn.close()
    return db_path

def get_header_offset_from_bytes(magic_4bytes, ext, file_size):
    header_offset = 0

    if ext == '.nes' and file_size > 16:
        if magic_4bytes == b'NES\x1a':
            header_offset = 16
    elif ext == '.smc':
        if file_size % 0x2000 == 512:
            header_offset = 512
    elif ext == '.a78' and file_size > 128:
        if magic_4bytes == b'ATARI':
            header_offset = 128
    elif ext == '.lnx' and file_size > 64:
        if magic_4bytes == b'LYNX':
            header_offset = 64
    elif ext in ['.sms', '.gg']:
        if file_size % 0x4000 == 512:
            header_offset = 512

    return header_offset

def get_header_offset(file_path, ext, file_size):
    if ext in ['.nes', '.a78', '.lnx']:
        with open(file_path, 'rb') as f:
            magic = f.read(4)
        return get_header_offset_from_bytes(magic, ext, file_size)
    return get_header_offset_from_bytes(b'', ext, file_size)

def hash_rom(file_path, header_offset):
    sha256_hash = hashlib.sha256()
    sha1_hash = hashlib.sha1()
    md5_hash = hashlib.md5()
    is_all_zero = True

    with open(file_path, 'rb') as f:
        f.seek(header_offset)
        while True:
            chunk = f.read(65536)
            if not chunk:
                break
            if is_all_zero and any(chunk):
                is_all_zero = False
            sha256_hash.update(chunk)
            sha1_hash.update(chunk)
            md5_hash.update(chunk)

    return sha256_hash.hexdigest(), sha1_hash.hexdigest(), md5_hash.hexdigest(), is_all_zero

def hash_zip_entry(zf, zip_info, header_offset):
    sha256_hash = hashlib.sha256()
    sha1_hash = hashlib.sha1()
    md5_hash = hashlib.md5()
    is_all_zero = True

    with zf.open(zip_info.filename, 'r') as f:
        if header_offset > 0:
            f.read(header_offset)
        while True:
            chunk = f.read(65536)
            if not chunk:
                break
            if is_all_zero and any(chunk):
                is_all_zero = False
            sha256_hash.update(chunk)
            sha1_hash.update(chunk)
            md5_hash.update(chunk)

    return sha256_hash.hexdigest(), sha1_hash.hexdigest(), md5_hash.hexdigest(), is_all_zero

def audit_hashes(cursor, sha256, sha1, md5, slow_mode):
    matched_entries = []
    method = ""

    def fetch_matches(column, value):
        cursor.execute(f"SELECT game_name, rom_name FROM roms WHERE {column} = ?", (value,))
        rows = cursor.fetchall()
        return [(r[0], r[1]) if r[1] else r[0] for r in rows]

    if not slow_mode:
        if sha1:
            matched_entries = fetch_matches("sha1", sha1)
            method = "SHA-1"
    else:
        if sha256:
            matched_entries = fetch_matches("sha256", sha256)
            method = "SHA-256"
        if not matched_entries and sha1:
            matched_entries = fetch_matches("sha1", sha1)
            method = "SHA-1 (Slow Fallback)"
        if not matched_entries and md5:
            matched_entries = fetch_matches("md5", md5)
            method = "MD5 (Slow Fallback)"

    return matched_entries, method

def process_single_file(file_path, db_path, slow_mode):
    with sqlite3.connect(db_path) as conn:
        cursor = conn.cursor()
        
        file_name = os.path.basename(file_path)
        ext = os.path.splitext(file_name)[1].lower()
        is_null = False
        display_cutoff = 5  
        
        # --- ZIP FILE PARSING LIFECYCLE ---
        if ext == '.zip':
            lines = [f"File: {file_name} [Zip Archive]"]
            total_entries = 0
            good_entries = 0
            
            try:
                with zipfile.ZipFile(file_path, 'r') as zf:
                    zip_infos = [z for z in zf.infolist() if not z.is_dir()]
                    total_entries = len(zip_infos)
                    
                    if total_entries == 0:
                        lines.append("  Result: Empty Zip Archive")
                        return file_name, False, "\n".join(lines) + "\n" + "-" * 50, False
                    
                    all_entries_are_zero = True
                    
                    for z_info in zip_infos:
                        inner_ext = os.path.splitext(z_info.filename)[1].lower()
                        inner_base_name = os.path.basename(z_info.filename)
                        
                        inner_header_offset = 0
                        if inner_ext in ['.nes', '.a78', '.lnx']:
                            with zf.open(z_info.filename, 'r') as f:
                                magic = f.read(4)
                            inner_header_offset = get_header_offset_from_bytes(magic, inner_ext, z_info.file_size)
                        else:
                            inner_header_offset = get_header_offset_from_bytes(b'', inner_ext, z_info.file_size)
                        
                        z_sha256, z_sha1, z_md5, z_is_zero = hash_zip_entry(zf, z_info, inner_header_offset)
                        
                        if z_is_zero:
                            entry_line = f"  -> Inside Zip: {z_info.filename}"
                            lines.extend([
                                entry_line,
                                f"     SHA-1:  {z_sha1}",
                                f"     MD5:    {z_md5}",
                                f"     SHA-256:{z_sha256}",
                                "     RESULT: [BAD/GHOST DUMP] Error: File payload consists entirely of blank null zeroes.",
                                "     " + "." * 30
                            ])
                            continue

                        all_entries_are_zero = False
                        matched_entries, method = audit_hashes(cursor, z_sha256, z_sha1, z_md5, slow_mode)
                        
                        entry_line = f"  -> Inside Zip: {z_info.filename}"
                        if inner_header_offset > 0:
                            entry_line += f" (Headered, Skipped {inner_header_offset} bytes)"
                        else:
                            entry_line += " (Headerless)"
                        lines.append(entry_line)
                        lines.append(f"     SHA-1:  {z_sha1}")
                        lines.append(f"     MD5:    {z_md5}")
                        lines.append(f"     SHA-256:{z_sha256}")
                        
                        if matched_entries:
                            good_entries += 1
                            matches_display = []
                            for entry in matched_entries[:display_cutoff]:
                                if isinstance(entry, tuple):
                                    g_name, r_name = entry
                                    if r_name and r_name.lower() == inner_base_name.lower():
                                        tag = "[Chip Match:" if inner_ext in ('.bin', '.rom', '.data') else "[Exact File Match:"
                                        matches_display.append(f"{g_name} {tag} {r_name}]")
                                    else:
                                        matches_display.append(g_name)
                                else:
                                    matches_display.append(entry)
                            
                            summary_str = ", ".join(matches_display)
                            if len(matched_entries) > display_cutoff:
                                summary_str += f" ... and {len(matched_entries) - display_cutoff} other machine variants (Shared BIOS/Driver)"
                            
                            lines.append(f"     RESULT: [GOOD MATCH] Variants: {summary_str} via {method}")
                        else:
                            lines.append("     RESULT: [UNKNOWN/BAD INNER FILE]")
                        lines.append("     " + "." * 30)
                    
                    if total_entries > 0 and all_entries_are_zero:
                        is_null = True
                       
            except zipfile.BadZipFile:
                lines.append("  RESULT: [CORRUPT ZIP ARCHIVE]")
                return file_name, False, "\n".join(lines) + "\n" + "-" * 50, False

            is_good = (good_entries == total_entries and total_entries > 0)
            if is_good:
                lines.append(f"  FINAL SUMMARY RESULT: [GOOD DUMP] All {good_entries}/{total_entries} sub-files authenticated.")
            else:
                if is_null:
                    lines.append("  FINAL SUMMARY RESULT: [BAD/GHOST ZIP] Entire archive container holds strictly empty zeroes.")
                else:
                    lines.append(f"  FINAL SUMMARY RESULT: [BAD/UNKNOWN DUMP] Found {total_entries - good_entries} unmapped sub-files.")
            lines.append("-" * 50)
            return file_name, is_good, "\n".join(lines), is_null

        # --- STANDARD / EXTRACTED FILE LIFECYCLE ---
        else:
            file_size = os.path.getsize(file_path)
            header_offset = get_header_offset(file_path, ext, file_size)
            sha256, sha1, md5, is_zero = hash_rom(file_path, header_offset)

            if is_zero:
                lines = [
                    f"File: {file_name}",
                    f"  Header Status: {'Headered' if header_offset > 0 else 'Headerless'}",
                    f"  SHA-1:  {sha1}",
                    f"  MD5:    {md5}",
                    f"  SHA-256:{sha256}",
                    "  RESULT: [BAD/GHOST DUMP] Error: File payload consists entirely of blank null zeroes.",
                    "-" * 50
                ]
                return file_name, False, "\n".join(lines), True

            matched_entries, method = audit_hashes(cursor, sha256, sha1, md5, slow_mode)
            match_tag = "[Extracted Chip Match:" if ext in ('.bin', '.rom', '.data') else "[Exact File Name Match:"

            if matched_entries:
                if len(matched_entries) == 1:
                    entry = matched_entries[0]
                    if isinstance(entry, tuple):
                        g_name, r_name = entry
                        if r_name and r_name.lower() == file_name.lower():
                            result = f"[GOOD DUMP] Matches: {g_name} {match_tag} {r_name}] via {method}"
                        else:
                            result = f"[GOOD DUMP] Matches: {g_name} via {method}"
                    else:
                        result = f"[GOOD DUMP] Matches: {entry} via {method}"
                else:
                    matches_display = []
                    for entry in matched_entries[:display_cutoff]:
                        if isinstance(entry, tuple):
                            g_name, r_name = entry
                            if r_name and r_name.lower() == file_name.lower():
                                matches_display.append(f"{g_name} {match_tag} {r_name}]")
                            else:
                                matches_display.append(g_name)
                        else:
                            matches_display.append(entry)
                    summary_str = ", ".join(matches_display)
                    if len(matched_entries) > display_cutoff:
                        summary_str += f" ... and {len(matched_entries) - display_cutoff} other machine variants (Shared BIOS/Driver)"
                    result = f"[GOOD DUMP] Matches: {summary_str} via {method}"
                is_good = True
            else:
                result = "[BAD/UNKNOWN DUMP]"
                is_good = False

            lines = [f"File: {file_name}"]
            if header_offset > 0:
                lines.append("  Header Status: Headered")
                lines.append(f"  Header Skipped: {header_offset} bytes")
            else:
                lines.append("  Header Status: Headerless")
            lines.extend([
                f"  SHA-1:  {sha1}",
                f"  MD5:    {md5}",
                f"  SHA-256:{sha256}",
                f"  RESULT: {result}",
                "-" * 50
            ])
            return file_name, is_good, "\n".join(lines), False

def verify_roms(dat_path, roms_dir, slow_mode=False, max_threads=None, delete_null_mode=False, purge_mode=False, filter_good=False, filter_bad=False):
    if slow_mode:
        print("Loading database (Slow Mode: Deep Audit [SHA-256 Anchor -> SHA-1/MD5 Fallbacks])...")
    else:
        print("Loading database (Fast Mode: Sequential [SHA-1 Anchor Only])...")
        
    db_path = parse_dats(dat_path)
    print(f"Recursively scanning: {roms_dir}")
    
    if max_threads is not None:
        if max_threads == 0:
            print("Threading enabled: Processing files in parallel utilizing maximum hardware capacity.")
        else:
            print(f"Threading enabled: Processing files in parallel utilizing {max_threads} worker thread(s).")
    else:
        print("Threading disabled: Processing sequentially (Safe for SD Cards).")

    if filter_good:
        print("Output Filter Active: Displaying and logging ONLY [GOOD DUMPS].")
    elif filter_bad:
        print("Output Filter Active: Displaying and logging ONLY [BAD/UNKNOWN DUMPS].")
    print("=" * 50)

    files_to_scan = []
    if os.path.isfile(roms_dir):
        if roms_dir.lower().endswith(VALID_EXTENSIONS) or roms_dir.lower().endswith(('.bin', '.rom', '.data')):
            files_to_scan.append(roms_dir)
    elif os.path.isdir(roms_dir):
        for root, _, files in os.walk(roms_dir):
            for file in files:
                if file.lower().endswith(VALID_EXTENSIONS) or file.lower().endswith(('.bin', '.rom', '.data')):
                    files_to_scan.append(os.path.join(root, file))

    total_files = len(files_to_scan)
    good_dumps = 0
    bad_dumps = 0
    report_lines = []
    deletion_queue = []

    def log_and_track(f_name, good_flag, text_block, null_flag, f_path):
        nonlocal good_dumps, bad_dumps
        if good_flag:
            good_dumps += 1
            if not filter_bad:
                print(f"[{good_dumps + bad_dumps}/{total_files}] Processed: {f_name} -> [GOOD]")
                report_lines.append(text_block)
        else:
            bad_dumps += 1
            if purge_mode:
                deletion_queue.append(f_path)
            elif delete_null_mode and null_flag:
                deletion_queue.append(f_path)
            if not filter_good:
                print(f"[{good_dumps + bad_dumps}/{total_files}] Processed: {f_name} -> [BAD/UNKNOWN]")
                report_lines.append(text_block)

    if max_threads is not None and total_files > 1:
        num_workers = None if max_threads == 0 else max_threads
        with ThreadPoolExecutor(max_workers=num_workers) as executor:
            futures = {executor.submit(process_single_file, fp, db_path, slow_mode): fp for fp in files_to_scan}
            for future in as_completed(futures):
                file_name, is_good, log_block, is_null = future.result()
                file_path = futures[future]
                log_and_track(file_name, is_good, log_block, is_null, file_path)
    else:
        for file_path in files_to_scan:
            file_name, is_good, log_block, is_null = process_single_file(file_path, db_path, slow_mode)
            log_and_track(file_name, is_good, log_block, is_null, file_path)

    report_dir = os.path.dirname(roms_dir) if os.path.isfile(roms_dir) else roms_dir
    report_path = os.path.join(report_dir, "rom_verification_report.txt")
    
    try:
        with open(report_path, 'w', encoding='utf-8') as rf:
            rf.write("ROM VERIFICATION REPORT\n")
            rf.write(f"Target Scan Directory: {roms_dir}\n")
            if filter_good:
                rf.write("Filtered Mode: [GOOD DUMPS ONLY]\n")
            elif filter_bad:
                rf.write("Filtered Mode: [BAD/UNKNOWN DUMPS ONLY]\n")
            rf.write("=" * 60 + "\n\n")
            rf.write("\n".join(report_lines))
            rf.write("\n\n" + "=" * 60 + "\n")
            rf.write(" VERIFICATION SUMMARY METRICS\n")
            rf.write("=" * 60 + "\n")
            rf.write(f" Total Files Analyzed: {total_files}\n")
            rf.write(f" Authenticated [GOOD] Dumps: {good_dumps}\n")
            rf.write(f" Unmapped / Corrupt [BAD] Dumps: {bad_dumps}\n")
            if delete_null_mode or purge_mode:
                rf.write(f" Total Items Flagged for Removal: {len(deletion_queue)}\n")
            rf.write("=" * 60 + "\n")
        print(f"\n[REPORT GENERATED] Summary report written to: {report_path}")
    except IOError as e:
        print(f"\n[ERROR] Failed writing summary report log file to disk: {e}")

    print("\n" + "=" * 50)
    print(" SCAN COMPLETED SUMMARY RESULTS")
    print("=" * 50)
    print(f" Total Files Checked: {total_files}")
    print(f" Authenticated Dumps (GOOD): {good_dumps}")
    print(f" Unmapped / Corrupt (BAD):  {bad_dumps}")
    print("=" * 50)

    if os.path.exists(db_path):
        try:
            os.remove(db_path)
        except OSError:
            pass

    # --- ACTION TRAP ENGINE ---
    if deletion_queue:
        deleted_count = 0
        print(f"\n[!] ACTION REQUIRED: System flagged {len(deletion_queue)} files for local storage cleanup.")
        if purge_mode:
            print(" -> Reason: Script ran with '--purge'. All unmapped/corrupt files will be dropped.")
        elif delete_null_mode:
            print(" -> Reason: Script ran with '--delete-null'. Ghost files filled entirely with blank zeroes will be dropped.")
        
        print("\nWARNING: This process modifies your local storage array permanently. Deleted files cannot be un-done.")
        confirm = input("Type 'CONFIRM' to execute filesystem deletion routine: ")
        
        if confirm == 'CONFIRM':
            print("\nExecuting filesystem wipe processing...")
            for item in deletion_queue:
                try:
                    os.remove(item)
                    print(f" [DELETED] Removed target file: {os.path.basename(item)}")
                    deleted_count += 1
                except OSError as err:
                    print(f" [ERROR] Could not un-link file target {item}: {err}")
            print(f"\nCompleted! Successfully wiped {deleted_count} file(s) from local filesystem arrays.")
        else:
            print("\nConfirmation entry mismatch! Operation aborted. Drive contents preserved.")

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: rom-ck <path_to_dat_or_folder> <path_to_roms_dir> [--slow] [--thread [num_threads]] [--delete-null] [--purge] [--only-good] [--only-bad]")
        sys.exit(1)

    dat_input = sys.argv[1]
    roms_input = sys.argv[2]
    slow_flag = "--slow" in sys.argv
    delete_null_flag = "--delete-null" in sys.argv
    purge_flag = "--purge" in sys.argv
    
    only_good_flag = "--only-good" in sys.argv
    only_bad_flag = "--only-bad" in sys.argv
    
    if only_good_flag and only_bad_flag:
        print("Error: Cannot use --only-good and --only-bad at the same time.")
        sys.exit(1)
        
    threads = None
    if "--thread" in sys.argv:
        idx = sys.argv.index("--thread")
        if idx + 1 < len(sys.argv) and sys.argv[idx + 1].isdigit():
            threads = int(sys.argv[idx + 1])
        else:
            threads = 0

    verify_roms(
        dat_path=dat_input,
        roms_dir=roms_input,
        slow_mode=slow_flag,
        max_threads=threads,
        delete_null_mode=delete_null_flag,
        purge_mode=purge_flag,
        filter_good=only_good_flag,
        filter_bad=only_bad_flag
    )
