#!/usr/bin/env python3
import sqlite3
import sys
import os
from xml.sax.saxutils import escape, quoteattr

def stream_db_to_dat(db_path, output_dat):
    if not os.path.exists(db_path):
        print(f"Error: Database file '{db_path}' not found.")
        sys.exit(1)

    print(f"Connecting to database: {db_path}...")
    # Open connection with speed optimizations for heavy sequential reading
    conn = sqlite3.connect(db_path)
    conn.execute("PRAGMA cache_size = -50000;")
    conn.execute("PRAGMA query_only = ON;")
    cursor = conn.cursor()

    try:
        # We drop the ORDER BY clause here. Keeping the original insertion order
        # prevents SQLite from scrambling the internal B-Tree page sorting rules
        # when you re-import this DAT back into rom-ck later!
        cursor.execute("SELECT game_name, rom_name, sha256, sha1, md5 FROM roms")
    except sqlite3.OperationalError as err:
        print(f"Database error: {err} (Is this a valid rom-ck cache database?)")
        conn.close()
        sys.exit(1)

    print(f"Writing to {output_dat} (Streaming layout)...")

    with open(output_dat, 'w', encoding='utf-8') as f:
        f.write('<?xml version="1.0" encoding="UTF-8"?>\n')
        f.write('<!DOCTYPE datafile PUBLIC "-//Logiqx//DTD ROM Management Datafile//EN" "http://www.logiqx.com/Dats/datafile.dtd">\n')
        f.write('<datafile>\n')
        f.write('    <header>\n')
        f.write('        <name>Exported Database Cache</name>\n')
        f.write(f'        <description>Exported from {os.path.basename(db_path)}</description>\n')
        f.write('        <version>1.0</version>\n')
        f.write('        <author>rom-ck streaming exporter</author>\n')
        f.write('    </header>\n')

        current_game_name = None

        for row in cursor:
            game_name, rom_name, sha256, sha1, md5 = row

            attr_game = quoteattr(game_name)

            # FIXED FALLBACK: If rom_name is NULL, we export it directly using the clean
            # game name string. rom-ck's O(1) split parser is smart enough to match it
            # without requiring a hardcoded extension!
            if rom_name:
                attr_rom = quoteattr(rom_name)
            else:
                attr_rom = attr_game

            text_game = escape(game_name)

            if game_name != current_game_name:
                if current_game_name is not None:
                    f.write('    </game>\n')
                f.write(f'    <game name={attr_game}>\n')
                f.write(f'        <description>{text_game}</description>\n')
                current_game_name = game_name

            f.write(f'        <rom name={attr_rom}')
            if sha256:
                f.write(f' sha256={quoteattr(sha256)}')
            if sha1:
                f.write(f' sha1={quoteattr(sha1)}')
            if md5:
                f.write(f' md5={quoteattr(md5)}')
            f.write('/>\n')

        if current_game_name is not None:
            f.write('    </game>\n')
        f.write('</datafile>')

    conn.close()
    print(f"Successfully exported to {output_dat}.")

if __name__ == "__main__":
    if len(sys.argv) != 3:
        print("Usage: db2dat <input.db> <output.dat>")
        sys.exit(1)
    stream_db_to_dat(sys.argv[1], sys.argv[2])
