#!/usr/bin/env python3
import os
import sys
import hashlib
import xml.etree.ElementTree as ET
from concurrent.futures import ThreadPoolExecutor, as_completed

# ==============================================================================
# MASTER VALID EXTENSIONS LIST
# ==============================================================================
VALID_EXTENSIONS = (
    # --- Nintendo ---
    '.z64', '.v64', '.n64', '.rom',  # Nintendo 64
    '.gba', '.gbc', '.gb',           # Game Boy, Color, Advance
    '.nes', '.sfc', '.smc',           # NES / SNES
    '.nds', '.3ds',                  # Nintendo DS / 3DS
    '.iso',                          # GameCube / Wii (Raw Discs)
    
    # --- Sega ---
    '.md', '.bin', '.gen',           # Genesis / Mega Drive
    '.32x',                          # Sega 32X
    '.sms',                          # Sega Master System
    '.gg',                           # Sega Game Gear
    
    # --- Atari ---
    '.a26', '.a52', '.a78', '.lnx',  # 2600, 5200, 7800, Lynx
    
    # --- SNK & Bandai ---
    '.ngp', '.ngc',                  # Neo Geo Pocket / Color
    '.ws', '.wsc',                   # WonderSwan / Color
    
    # --- NEC & Miscellaneous ---
    '.pce',                          # TurboGrafx-16 / PC Engine
    '.pbp',                          # PlayStation Portable / PSX Eboots
    '.chd', '.cue'                   # CD/Disc compression formats
)

def parse_dats(dat_path):
    db = {'sha256': {}, 'sha1': {}, 'md5': {}}
    dat_files = []

    if os.path.isdir(dat_path):
        for root, _, files in os.walk(dat_path):
            for file in files:
                if file.lower().endswith('.dat'):
                    dat_files.append(os.path.join(root, file))
    elif os.path.isfile(dat_path):
        dat_files.append(dat_path)

    if not dat_files:
        print(f"Error: No valid .dat file found at {dat_path}")
        sys.exit(1)

    for dat in dat_files:
        try:
            tree = ET.parse(dat)
            root = tree.getroot()
            for game in root.findall('.//game') + root.findall('.//machine'):
                game_name = game.get('name')
                for rom in game.findall('rom'):
                    sha256 = rom.get('sha256')
                    sha1 = rom.get('sha1')
                    md5 = rom.get('md5')

                    # Store in lists to properly track variants/hash collisions
                    if sha1:
                        sha1_lower = sha1.lower()
                        if sha1_lower not in db['sha1']: db['sha1'][sha1_lower] = []
                        db['sha1'][sha1_lower].append(game_name)
                    if sha256:
                        sha256_lower = sha256.lower()
                        if sha256_lower not in db['sha256']: db['sha256'][sha256_lower] = []
                        db['sha256'][sha256_lower].append(game_name)
                    if md5:
                        md5_lower = md5.lower()
                        if md5_lower not in db['md5']: db['md5'][md5_lower] = []
                        db['md5'][md5_lower].append(game_name)
        except ET.ParseError as e:
            print(f"Error parsing DAT {dat}: {e}")
            continue
    return db

def get_header_offset(file_path, ext, file_size):
    header_offset = 0

    if ext == '.nes' and file_size > 16:
        with open(file_path, 'rb') as f:
            magic = f.read(4)
            if magic == b'NES\x1a':
                header_offset = 16

    elif ext == '.smc':
        if file_size % 0x2000 == 512:
            header_offset = 512

    elif ext == '.a78' and file_size > 128:
        with open(file_path, 'rb') as f:
            magic = f.read(4)
            if magic == b'ATARI':
                header_offset = 128

    elif ext == '.lnx' and file_size > 64:
        with open(file_path, 'rb') as f:
            magic = f.read(4)
            if magic == b'LYNX':
                header_offset = 64

    elif ext in ['.sms', '.gg']:
        if file_size % 0x4000 == 512:
            header_offset = 512

    return header_offset

def hash_rom(file_path, header_offset):
    sha256_hash = hashlib.sha256()
    sha1_hash = hashlib.sha1()
    md5_hash = hashlib.md5()

    with open(file_path, 'rb') as f:
        f.seek(header_offset)
        while True:
            chunk = f.read(65536)
            if not chunk:
                break
            sha256_hash.update(chunk)
            sha1_hash.update(chunk)
            md5_hash.update(chunk)

    return sha256_hash.hexdigest(), sha1_hash.hexdigest(), md5_hash.hexdigest()

def process_single_file(file_path, db, slow_mode):
    file_name = os.path.basename(file_path)
    ext = os.path.splitext(file_name)[1].lower()
    file_size = os.path.getsize(file_path)

    header_offset = get_header_offset(file_path, ext, file_size)
    sha256, sha1, md5 = hash_rom(file_path, header_offset)

    matched_games = []
    method = ""

    # ==========================================================================
    # AUDIT LOGIC (SHA-1 Fast Default vs Dynamic Cascading Fallback Slow Mode)
    # ==========================================================================
    if not slow_mode:
        # Fast Mode: Only anchor and verify via SHA-1
        if sha1 in db['sha1']:
            matched_games = db['sha1'][sha1]
            method = "SHA-1"
    else:
        # Slow Mode: Look up SHA-256 first
        if sha256 in db['sha256']:
            matched_games = db['sha256'][sha256]
            method = "SHA-256"
        # Slow Fallback 1: Fall back to SHA-1 if SHA-256 is missing in the DAT entries
        elif sha1 in db['sha1']:
            matched_games = db['sha1'][sha1]
            method = "SHA-1 (Slow Fallback)"
        # Slow Fallback 2: Fall back to MD5 if both SHA options are missing in the DAT
        elif md5 in db['md5']:
            matched_games = db['md5'][md5]
            method = "MD5 (Slow Fallback)"

    if matched_games:
        # Handle duplicate hash hits or regional clone variants listed under a shared dump
        if len(matched_games) > 1:
            result = f"[GOOD DUMP] Matches multiple variants: {', '.join(matched_games)} via {method}"
        else:
            result = f"[GOOD DUMP] Matches: {matched_games[0]} via {method}"
        is_good = True
    else:
        result = "[BAD/UNKNOWN DUMP]"
        is_good = False

    lines = [f"File: {file_name}"]
    if header_offset > 0:
        lines.append(f"  Header Skipped: {header_offset} bytes")
    lines.extend([
        f"  SHA-1:  {sha1}",
        f"  MD5:    {md5}",
        f"  SHA-256:{sha256}",
        f"  RESULT: {result}",
        "-" * 50
    ])
    
    return file_name, is_good, "\n".join(lines)

def verify_roms(dat_path, roms_dir, slow_mode=False, use_threading=False):
    if slow_mode:
        print("Loading database (Slow Mode: Deep Audit [SHA-256 Anchor -> SHA-1/MD5 Fallbacks])...")
    else:
        print("Loading database (Fast Mode: Sequential [SHA-1 Anchor Only])...")
        
    db = parse_dats(dat_path)

    print(f"Recursively scanning: {roms_dir}")
    if use_threading:
        print("Threading enabled: Processing files in parallel via ThreadPoolExecutor.")
    else:
        print("Threading disabled: Processing sequentially (Safe for SD Cards).")
    print("=" * 50)

    files_to_scan = []
    for root, _, files in os.walk(roms_dir):
        for file in files:
            if file.lower().endswith(VALID_EXTENSIONS):
                files_to_scan.append(os.path.join(root, file))

    total_files = len(files_to_scan)
    good_dumps = 0
    bad_dumps = 0
    report_lines = []

    if use_threading and total_files > 1:
        with ThreadPoolExecutor() as executor:
            futures = {executor.submit(process_single_file, fp, db, slow_mode): fp for fp in files_to_scan}
            
            for idx, future in enumerate(as_completed(futures), 1):
                file_name, is_good, log_block = future.result()
                print(f"[{idx}/{total_files}] Processed: {file_name}")
                if is_good: good_dumps += 1
                else: bad_dumps += 1
                report_lines.append(log_block)
    else:
        for idx, file_path in enumerate(files_to_scan, 1):
            file_name, is_good, log_block = process_single_file(file_path, db, slow_mode)
            print(f"[{idx}/{total_files}] Scanning: {file_name}")
            if is_good: good_dumps += 1
            else: bad_dumps += 1
            report_lines.append(log_block)

    report_path = os.path.join(roms_dir, "recursive_rom_verification_report.txt")
    with open(report_path, "w") as f:
        f.write(f"Recursive ROM Verification Report for: {roms_dir}\n")
        f.write("=" * 70 + "\n")
        f.write("\n".join(report_lines))
        f.write(f"\n\nVerification Summary:\n")
        f.write(f"Total Good Dumps: {good_dumps}\n")
        f.write(f"Total Bad/Unknown Dumps: {bad_dumps}\n")

    print("\n" + "=" * 50)
    print("Verification Summary:")
    print(f"Total Good Dumps: {good_dumps}")
    print(f"Total Bad/Unknown Dumps: {bad_dumps}")
    print(f"\nDone! Master report saved to: {report_path}")

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: rom-ck <path_to_dat_or_folder> <path_to_roms_dir> [--slow] [--thread]")
        sys.exit(1)

    dat_input = sys.argv[1]
    roms_input = sys.argv[2]
    slow_flag = "--slow" in sys.argv
    thread_flag = "--thread" in sys.argv

    verify_roms(dat_input, roms_input, slow_mode=slow_flag, use_threading=thread_flag)
